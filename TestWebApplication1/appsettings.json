{
  "Logging": {
    "IndustrialLogger": {
      "GlobalMinLevel": "Information",
      "SampleRate": 1.0,
      "TextTemplate": "{UtcTimestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level}] [{Module}] {Scope} {Message} {Exception}",
      "TimestampType": "Beijing",
      "BatchSize": 50,
      "ChannelCapacity": 1048576,
      "FlushIntervalMs": 1000,
      "FileExpireMinutes": 5,

      "Console": {
        "Enabled": true,
        "MinLevel": "Debug",
        "Format": "Text"
      },

      "File": {
        "Enabled": true,
        "MinLevel": "Information",
        "Format": "Text",
        "RootPath": "logs",
        "MaxFileSizeMB": 20,
        "MaxBackupCount": 20,
        "RollingInterval": "Day",
        "EnableCompress": true,
        "FileName": "app-log"
      },

      "Filter": {
        "Enabled": true,
        "IncludeModules": [],
        "ExcludeModules": [ "Microsoft", "System" ],
        "BlockKeywords": [ "密码", "token" ]
      },

      "SensitiveMask": {
        "Enabled": true,
        "Rules": {
          "1[3-9]\\d{9}": "1****$&",
          "\\d{18}|\\d{17}[xX]": "****************$&",
          "\\d+@\\w+\\.\\w+": "***@***"
        }
      }
    }
  }
}